# ─── Database ────────────────────────────────────────────────────────────────
# Local dev can still use SQLite. Production (Railway) MUST use PostgreSQL.
# Railway auto-injects DATABASE_URL when you add the PostgreSQL plugin.
# Local example:  postgresql://user:password@localhost:5432/horizon_os
DATABASE_URL="postgresql://user:password@localhost:5432/horizon_os"

# ─── Auth (both required — server throws on startup if either is missing) ──────
JWT_SECRET="generate-a-strong-64-char-random-string"
JWT_REFRESH_SECRET="generate-a-different-strong-64-char-random-string"

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# Do NOT set PORT on Railway — it is injected automatically. Used for local dev only.
PORT=3001

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production set this to your Vercel
# desktop URL (and any other clients), e.g. https://horizon-os.vercel.app
CORS_ORIGINS="http://localhost:3000"
