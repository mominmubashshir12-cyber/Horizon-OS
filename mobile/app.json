{
  "expo": {
    "name": "Horizon OS",
    "slug": "horizon-os-mobile",
    "scheme": "horizon-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.horizonit.horizonos"
    },
    "android": {
      "package": "com.horizonit.horizonos",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Horizon OS to access your camera for scanning and capturing job photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Horizon OS to use your location for attendance tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.1.15:3001/api",
      "wsUrl": "ws://192.168.1.15:3001",
      "router": {},
      "eas": {
        "projectId": "9edcd353-3884-4a5c-b894-402ca73c7c96"
      }
    }
  }
}
